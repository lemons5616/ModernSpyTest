-- ModernSpy
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "ModernSpy"

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 500, 0, 300)
main.Position = UDim2.new(0.5, -250, 0.5, -150)
main.BackgroundColor3 = Color3.fromRGB(25,25,25)
main.Active = true
Instance.new("UICorner", main)

-- TITLE
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,25)
title.BackgroundTransparency = 1
title.Text = "ModernSpy"
title.TextColor3 = Color3.new(1,1,1)

-- FILTER BOX
local filter = Instance.new("TextBox", main)
filter.PlaceholderText = "FilterBy..."
filter.Size = UDim2.new(0,150,0,25)
filter.Position = UDim2.new(1,-160,0,0)

-- LIST
local listFrame = Instance.new("ScrollingFrame", main)
listFrame.Size = UDim2.new(0,200,1,-40)
listFrame.Position = UDim2.new(0,0,0,30)
listFrame.CanvasSize = UDim2.new(0,0,0,0)
listFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)

local layout = Instance.new("UIListLayout", listFrame)

-- CONSOLE
local console = Instance.new("TextLabel", main)
console.Size = UDim2.new(1,-210,1,-70)
console.Position = UDim2.new(0,210,0,30)
console.BackgroundColor3 = Color3.fromRGB(20,20,20)
console.TextColor3 = Color3.new(1,1,1)
console.TextXAlignment = Enum.TextXAlignment.Left
console.TextYAlignment = Enum.TextYAlignment.Top
console.Text = ""
console.TextWrapped = true

-- COPY BUTTON
local copyBtn = Instance.new("TextButton", main)
copyBtn.Size = UDim2.new(0,150,0,30)
copyBtn.Position = UDim2.new(1,-160,1,-35)
copyBtn.Text = "Copy Path"

-- DATA
local logs = {}
local selected

-- FUNCIONES
local function refreshList()
	listFrame:ClearAllChildren()
	layout.Parent = listFrame
	
	local keyword = string.lower(filter.Text)

	for _, log in ipairs(logs) do
		if keyword == "" or string.find(string.lower(log.name), keyword) then
			
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1,0,0,20)
			btn.Text = log.name
			btn.Parent = listFrame
			
			btn.MouseButton1Click:Connect(function()
				selected = log
				console.Text = "Path: "..log.path.."\nArgs:\n"..log.args
			end)
		end
	end
	
	listFrame.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end

filter:GetPropertyChangedSignal("Text"):Connect(refreshList)

-- COPY
copyBtn.MouseButton1Click:Connect(function()
	if selected then
		setclipboard(selected.path)
	end
end)

-- HOOK
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
	local method = getnamecallmethod()
	local args = {...}

	if method == "FireServer" or method == "InvokeServer" then
		local log = {
			name = self.Name,
			path = self:GetFullName(),
			args = ""
		}
		
		for i,v in pairs(args) do
			log.args = log.args .. "["..i.."]: "..tostring(v).."\n"
		end
		
		table.insert(logs, 1, log)
		refreshList()
	end
	
	return old(self, ...)
end)

setreadonly(mt, true)

-- DRAG (PC + MOBILE)
local dragging, dragStart, startPos

main.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)
