local events = "=== RemoteEvents ===\n"
local functions = "\n=== RemoteFunctions ===\n"

for _, obj in ipairs(game:GetDescendants()) do
	if obj:IsA("RemoteEvent") then
		events = events .. obj:GetFullName().."\n"
	end
	
	if obj:IsA("RemoteFunction") then
		functions = functions .. obj:GetFullName().."\n"
	end
end

setclipboard(events..functions)

print("🔥 Remotes organizados copiados")
